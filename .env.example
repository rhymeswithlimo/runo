# ── Required ─────────────────────────────────────────────────────────────────
# A Google Gemini API key. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: several comma-separated keys for round-robin (helps avoid per-key
# rate limits under load). If set, this takes precedence over GEMINI_API_KEY.
# GEMINI_API_KEYS=key1,key2,key3

# ── Optional tunables (sensible defaults — uncomment only to change) ──────────
# Headless rendering engine for JS-heavy pages: patchright | camoufox | playwright
# HEADLESS_ENGINE=patchright
# Pre-launch Chromium at server startup so the first JS page isn't slow.
# PREWARM_BROWSER=true
# TLS impersonation target for the plain-fetch path (needs the [tls] extra):
# chrome124 | chrome120 | safari17_0 | firefox125 | off
# TLS_IMPERSONATE=chrome124
# Gemini chain-of-thought budget (tokens). 512 is the API floor.
# LITE_THINKING_BUDGET=512
# Reject fetches to private/loopback/metadata IPs. Leave on unless you have a
# specific reason to scrape localhost / internal hosts.
# SSRF_GUARD_ENABLED=true
